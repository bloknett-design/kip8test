# ============================================================
# .gitignore для репозитория kip8test
# ============================================================
# Этот файл указывает git, какие файлы и папки игнорировать —
# они не попадут в коммиты и не засорят репозиторий.
# Правила применяются ко всем подпапкам рекурсивно.
# ============================================================

# === Артефакты ОС ===
# desktop.ini — создаётся Google Drive Stream на Windows в каждой папке,
#   которую синхронизирует Drive. Содержит путь к иконке папки.
#   Не нужен в репозитории, но если удалить его с диска локально —
#   Drive Stream создаст заново при следующей синхронизации.
desktop.ini

# .DS_Store — создаётся macOS Finder в каждой папке (метаданные просмотра).
.DS_Store

# Thumbs.db, thumbs.db — кэш миниатюр проводника Windows.
Thumbs.db
thumbs.db

# === Python ===
# __pycache__/ — байт-код Python (*.pyc), генерируется при запуске
#   scripts/sync-*.py и scripts/convert-exam-tickets.py.
__pycache__/
*.pyc
*.pyo

# === Node.js ===
# node_modules/ — зависимости, если кто-то решит поставить Jest/ESLint
#   для тестов (сейчас tests/run-all.js работает без зависимостей,
#   но правило полезно на будущее).
node_modules/

# === IDE и редакторы ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Временные и лог-файлы ===
*.log
*.tmp
*.bak

# === Локальные скачивания sync-скриптов ===
# sync-devices.py и др. скачивают xlsx во временную папку /tmp/devices_download/.
# На GitHub Actions это безопасно (эферемный runner), но локально — мусор.
/tmp/devices_download/

# === Секреты и ключи подписи ===
# На случай, если кто-то случайно положит signing.keystore (для TWA/APK)
# или файл с токенами в корень репозитория — критично не коммитить.
signing.keystore
*.keystore
.env
.env.local
